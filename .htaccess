RewriteEngine On

# ─── SECURITY ────────────────────────────────────────────────────────────────
# Block direct access to debug/sensitive files
<FilesMatch "^(check_db|schema|promt|catalog_parse|catalog_info|table)\.(php|sql|txt|md)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Block direct access to backend source includes
RewriteRule ^backend/includes/ - [F,L]
RewriteRule ^backend/config\.php$ - [F,L]

# ─── PERFORMANCE: Gzip compression ──────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json application/xml text/xml text/plain
</IfModule>

# Browser caching for static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/png  "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType text/css   "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
</IfModule>


# Route home page
RewriteRule ^$ index.php [L]

# Route categories page
RewriteRule ^categories/?$ categories.php [L]

# Route deals page
RewriteRule ^deals/?$ deals.php [L]

# Route sitemap
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Route robots.txt to root file
RewriteRule ^robots\.txt$ robots.txt [L]

# Route product pages
RewriteRule ^product/([a-zA-Z0-9_\-]+) product.php?id=$1 [QSA,L]

# Route individual category pages
RewriteRule ^category/([a-zA-Z0-9_\-]+) category.php?id=$1 [QSA,L]

# SPA fallback: JS-only routes (cart, login, orders, profile, admin, search)
# load index.html so the SPA router handles them client-side
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(cart|login|orders|profile|admin|search)/?$ frontend/dist/index.html [L]

# All other unmatched URLs → 404
ErrorDocument 404 /course__udemy/404.php
